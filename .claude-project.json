{
  "project_type": "python",
  "has_tests": false,
  "has_build": false,
  "has_frontend": false,
  "has_app": false,
  "checks": {
    "lint": {
      "command_patterns": ["ruff check", "flake8"],
      "pass_patterns": ["All checks passed", "^$"],
      "fail_patterns": ["Found \\d+ error", "E\\d+"],
      "run_command": "ruff check . && flake8 ."
    },
    "typecheck": {
      "required": false
    },
    "tests": {
      "required": false
    }
  }
}
